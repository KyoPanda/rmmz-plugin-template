{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM"],

        "types": ["rmmz"],

        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,

        "skipLibCheck": true,
        "skipDefaultLibCheck": true,

        "isolatedModules": true,
        "noEmitOnError": true,

        "verbatimModuleSyntax": false,
        "ignoreDeprecations": "5.0"
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
